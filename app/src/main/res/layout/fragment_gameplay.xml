<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Header with Level and Timer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Level 1"
            android:textColor="@color/red"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Moves: 0"
                android:textColor="@color/red"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:05"
                android:textColor="@color/teal_700"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Pieces counter -->
    <TextView
        android:id="@+id/tv_pieces"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 / 16 Pieces Placed"
        android:textColor="@color/cyan"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- Puzzle board (fills available space) -->
    <com.puzzlequest.game.ui.views.PuzzleBoardView
        android:id="@+id/puzzle_board"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white" />

    <!-- Instruction text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎯 Drag pieces. Drop on correct spot to lock."
        android:textColor="@color/red"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

    <!-- Icon-only button controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="8dp"
        android:spacing="16dp">

        <Button
            android:id="@+id/btn_hint"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="💡"
            android:textSize="28sp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/yellow"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_restart"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="🔄"
            android:textSize="28sp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/red"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_home"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="🏠"
            android:textSize="28sp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/gray"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_more_time"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="⏱️"
            android:textSize="28sp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/red"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

</LinearLayout>
